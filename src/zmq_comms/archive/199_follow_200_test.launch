<launch>
    <!-- 199 drone starts at origin -->
    <param name="x_offset" value="0.0" />
    <param name="y_offset" value="0.0" />
    <param name="z_offset" value="0.0" />
    <node pkg="zmq_comms" type="pub_self_position.py" name="self_pose_publisher" output="screen">
    </node>

    <param name="goal_publisher_address" value="tcp://192.168.65.100:5555" />
    <param name="other_drone_address1" value="tcp://192.168.65.200:5555" />
    <node pkg="zmq_comms" type="listen_to_others.py" name="listen_to_200_pose" output="screen">
        <remap from="/other_drone/global_position/pose" to="/drone_200/global_position/pose" />
        <remap from="/other_drone/global_position/odom" to="/drone_200/global_position/odom" />
    </node>

    <node pkg="zmq_comms" type="follow_other_drone.py" name="follow_200_pose" output="screen">
        <remap from="/other_drone/global_position/pose" to="/drone_200/global_position/pose" />
    </node>

</launch>
